{
  "name": "portfolio",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "start": "cross-env SOCKET=true NODE_OPTIONS=--require=./scripts/fix-punycode.cjs node ./scripts/next-remote-watch.js ./data",
    "dev": "cross-env NODE_OPTIONS=--require=./scripts/fix-punycode.cjs next dev",
    "build": "cross-env NODE_OPTIONS=--require=./scripts/fix-punycode.cjs next build && next-sitemap",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true NODE_OPTIONS=--require=./scripts/fix-punycode.cjs next build",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "preview": "npm run build && npm run serve"
  },
  "dependencies": {
    "@fontsource/fira-code": "5.2.7",
    "@fontsource/open-sans": "5.2.7",
    "@geist-ui/core": "2.3.8",
    "@mailchimp/mailchimp_marketing": "3.0.80",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/typography": "0.5.20",
    "clsx": "2.1.1",
    "esbuild": "0.25.12",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "image-size": "2.0.2",
    "js-yaml": "5.2.1",
    "katex": "0.16.22",
    "mdast-util-to-string": "4.0.0",
    "mdx-bundler": "10.1.1",
    "next": "16.2.10",
    "next-sitemap": "4.2.3",
    "next-themes": "0.4.6",
    "postcss": "8.5.6",
    "punycode": "2.3.1",
    "react": "19.2.7",
    "react-calendly": "4.4.0",
    "react-dom": "19.2.7",
    "react-icons": "5.5.0",
    "react-indiana-drag-scroll": "2.2.1",
    "react-rough-notation": "1.0.8",
    "react-share": "5.2.2",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-citation": "2.3.1",
    "rehype-katex": "7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "2.0.1",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "sharp": "0.34.4",
    "smoothscroll-polyfill": "0.4.4",
    "tailwindcss": "4.3.2",
    "unist-util-visit": "5.0.0",
    "vfile": "6.0.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.10",
    "@types/js-yaml": "4.0.9",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/unist": "3.0.3",
    "axios": "1.13.2",
    "cross-env": "7.0.3",
    "dedent": "1.5.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "globby": "11.1.0",
    "husky": "9.1.7",
    "inquirer": "8.2.6",
    "lint-staged": "15.5.2",
    "next-remote-watch": "2.0.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.8.0",
    "socket.io": "4.8.1",
    "socket.io-client": "4.8.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}
