---
import Container from '@/components/Container.astro';
import type { Contact, Site } from '@/lib/data';

interface Props {
  site: Site;
  contact: Contact;
}

const { site, contact } = Astro.props;
const year = new Date().getFullYear();
const [firstName, ...rest] = site.author.split(' ');
const lastName = rest.join(' ');
---

<footer class="footer-reveal">
  <Container
    class="flex min-h-[40vh] flex-col justify-between gap-10 py-16 sm:min-h-[44vh] sm:py-20"
  >
    <div class="max-w-xl">
      <div class="brand-eyebrow flex items-center gap-4">
        <span aria-hidden class="brand-eyebrow-rule"></span>
        <p class="text-[0.7rem] font-medium tracking-[0.32em] uppercase">
          Thanks for visiting
        </p>
      </div>
      <p
        class="font-display mt-5 text-4xl leading-[0.92] tracking-[-0.02em] text-ink sm:text-5xl"
      >
        <span class="block">{firstName}</span>
        {
          lastName ? (
            <span class="footer-lastname mt-1 block">{lastName}</span>
          ) : null
        }
      </p>
      <p class="mt-5 max-w-sm text-base leading-relaxed text-ink-muted">
        Built with care — open to thoughtful collaborations.
      </p>
      <div aria-hidden class="brand-divider mt-8"></div>
    </div>

    <div
      class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end"
    >
      <p class="text-sm tracking-wide text-ink-muted">© {year}</p>
      <nav aria-label="Social">
        <ul class="flex flex-wrap gap-5 text-sm">
          <li>
            <a
              href={contact.links.github}
              class="text-ink-muted link-underline hover:text-sage"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href={contact.links.linkedin}
              class="text-ink-muted link-underline hover:text-sage"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href={contact.links.email}
              class="text-ink-muted link-underline hover:text-sage"
            >
              Email
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </Container>
</footer>
