---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  description?: string;
  animate?: boolean;
}

const {
  id,
  eyebrow,
  title,
  description,
  animate = true,
} = Astro.props;
---

<header class={`brand-heading max-w-2xl ${animate ? 'reveal' : ''}`}>
  <div class="brand-eyebrow mb-4 flex items-center gap-4 sm:mb-5">
    <span aria-hidden class="brand-eyebrow-rule"></span>
    <p class="text-[0.7rem] font-medium tracking-[0.32em] uppercase">
      {eyebrow}
    </p>
  </div>
  <h2
    id={id}
    class="font-display title-underline text-4xl leading-[0.95] tracking-[-0.02em] text-ink sm:text-5xl"
  >
    {title}
  </h2>
  {
    description ? (
      <p class="mt-5 max-w-xl text-base leading-relaxed text-ink-muted sm:mt-6 sm:text-lg">
        {description}
      </p>
    ) : null
  }
</header>
