---
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import type { Profile } from '@/lib/data';

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const [lead, ...rest] = profile.bio;
---

<Section
  id="about"
  labelledBy="about-heading"
  class="brand-section relative overflow-hidden"
>
  <div
    aria-hidden
    class="brand-wash brand-wash-tl pointer-events-none absolute top-12 left-0 -translate-x-1/3"
  >
    <div
      class="parallax-slow h-64 w-64 rounded-full bg-gradient-to-br from-sky-mist/30 via-gold-soft/8 to-transparent"
    >
    </div>
  </div>

  <SectionHeading id="about-heading" eyebrow="Story" title="About" />

  <div class="about-layout mt-12 md:mt-16">
    <p class="about-lead reveal font-display">{lead}</p>

    <div class="about-split">
      <figure class="about-frame reveal-left">
        <div class="about-matte">
          <img
            src={profile.avatar}
            alt={`Portrait of ${profile.name}`}
            width="400"
            height="500"
            decoding="async"
            loading="lazy"
            class="about-portrait-img"
          />
        </div>
      </figure>

      <div class="about-body reveal reveal-delay-1">
        {rest.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </div>
</Section>
