---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/400-italic.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/500-italic.css';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/jetbrains-mono/600-italic.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/jetbrains-mono/700-italic.css';
import StructuredData from '@/components/StructuredData.astro';
import { getProfile, getSite } from '@/lib/data';
import '@/styles/global.css';

const site = getSite();
const profile = getProfile();
const pageTitle = `${site.title} — ${profile.occupation}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3f1ec" />
    <meta name="color-scheme" content="light" />

    <title>{pageTitle}</title>
    <meta name="description" content={site.description} />
    <meta name="application-name" content={site.title} />
    <meta name="author" content={site.author} />
    <meta name="creator" content={site.author} />
    <meta
      name="keywords"
      content="Abdelfatah Ashour, Frontend Engineer, React, Next.js, TypeScript, Portfolio"
    />
    <link rel="canonical" href={site.siteUrl} />

    <meta name="robots" content="index, follow" />
    <meta
      name="googlebot"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={site.siteUrl} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={site.description} />
    <meta property="og:image" content={`${site.siteUrl}/static/brand/og.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={site.description} />
    <meta
      name="twitter:image"
      content={`${site.siteUrl}/static/brand/twitter.png`}
    />
    <meta name="twitter:creator" content="@abdoashour07" />

    <link rel="icon" href="/static/brand/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/static/brand/favicon-16x16.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/static/brand/favicon-32x32.png"
    />
    <link rel="apple-touch-icon" href="/static/brand/apple-touch-icon.png" />
    <link rel="manifest" href="/static/brand/site.webmanifest" />
  </head>
  <body class="font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:rounded-sm focus:bg-ink focus:px-4 focus:py-2 focus:text-mist"
    >
      Skip to content
    </a>
    <StructuredData site={site} profile={profile} />
    <slot />
  </body>
</html>
